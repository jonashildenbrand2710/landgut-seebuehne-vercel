{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Code Factory project configuration",
  "type": "object",
  "additionalProperties": false,
  "required": ["language", "linear", "github", "commands", "cursor", "review", "repair", "preview"],
  "properties": {
    "language": { "enum": ["de", "en"] },
    "linear": {
      "type": "object",
      "additionalProperties": false,
      "required": ["teamKey", "readyLabel", "blockedLabel", "reviewStatus"],
      "properties": {
        "teamKey": { "type": "string", "minLength": 1 },
        "readyLabel": { "type": "string", "minLength": 1 },
        "blockedLabel": { "type": "string", "minLength": 1 },
        "reviewStatus": { "type": "string", "minLength": 1 }
      }
    },
    "github": {
      "type": "object",
      "additionalProperties": false,
      "required": ["repository", "baseBranch", "requiredChecks"],
      "properties": {
        "repository": { "type": "string", "pattern": "^[^/]+/[^/]+$" },
        "baseBranch": { "type": "string", "minLength": 1 },
        "requiredChecks": { "type": "array", "items": { "type": "string", "minLength": 1 }, "uniqueItems": true }
      }
    },
    "commands": {
      "type": "object",
      "additionalProperties": false,
      "required": ["install", "lint", "typecheck", "test", "build", "start", "port"],
      "properties": {
        "install": { "type": "string" },
        "lint": { "type": "string" },
        "typecheck": { "type": "string" },
        "test": { "type": "string" },
        "build": { "type": "string" },
        "start": { "type": "string" },
        "port": { "type": "integer", "minimum": 1, "maximum": 65535 }
      }
    },
    "cursor": {
      "type": "object",
      "additionalProperties": false,
      "required": ["dispatchMode", "modelPolicy", "buildOptimization", "repairOptimization", "reviewOptimization", "allowFixedModelOverride"],
      "properties": {
        "dispatchMode": { "const": "linear-agent" },
        "modelPolicy": { "const": "auto" },
        "buildOptimization": { "enum": ["cost", "balance", "intelligence"] },
        "repairOptimization": { "enum": ["cost", "balance", "intelligence"] },
        "reviewOptimization": { "enum": ["cost", "balance", "intelligence"] },
        "allowFixedModelOverride": { "const": false }
      }
    },
    "review": {
      "type": "object",
      "additionalProperties": false,
      "required": ["provider", "evidenceSkill", "automationProvider", "triggerLabel", "approvedLabel", "changesRequestedLabel", "humanReviewLabel", "rerunOnPush", "humanMergeOnly"],
      "properties": {
        "provider": { "const": "finn-review" },
        "evidenceSkill": { "const": "evidence-driven-testing" },
        "automationProvider": { "const": "cursor-automation" },
        "triggerLabel": { "const": "factory-review-ready" },
        "approvedLabel": { "const": "factory-approved" },
        "changesRequestedLabel": { "const": "loop-changes-requested" },
        "humanReviewLabel": { "const": "needs-human-review" },
        "rerunOnPush": { "const": true },
        "humanMergeOnly": { "const": true }
      }
    },
    "repair": {
      "type": "object",
      "additionalProperties": false,
      "required": ["enabled", "automationProvider", "triggerLabel", "runningLabel", "limitLabel", "issueLabel", "maxAutomaticRoundsPerGate", "createLinearSubIssue", "reusePullRequest", "inheritBuildApproval", "resetAfterHumanDecision"],
      "properties": {
        "enabled": { "const": true },
        "automationProvider": { "const": "cursor-automation" },
        "triggerLabel": { "const": "loop-changes-requested" },
        "runningLabel": { "const": "factory-repair-running" },
        "limitLabel": { "const": "repair-limit-reached" },
        "issueLabel": { "const": "factory-repair" },
        "maxAutomaticRoundsPerGate": { "const": 3 },
        "createLinearSubIssue": { "const": true },
        "reusePullRequest": { "const": true },
        "inheritBuildApproval": { "const": true },
        "resetAfterHumanDecision": { "const": true }
      }
    },
    "preview": {
      "type": "object",
      "additionalProperties": false,
      "required": ["provider", "required"],
      "properties": {
        "provider": { "enum": ["vercel", "other", "none"] },
        "required": { "type": "boolean" }
      }
    }
  }
}
