{
  "$schema": "./factory.schema.json",
  "language": "de",
  "linear": {
    "teamKey": "JON",
    "readyLabel": "agent-ready",
    "blockedLabel": "blocked",
    "reviewStatus": "In Review"
  },
  "github": {
    "repository": "jonashildenbrand2710/landgut-seebuehne-vercel",
    "baseBranch": "main",
    "stagingBranch": "staging",
    "pullRequestBaseBranch": "staging",
    "requiredChecks": ["quality"]
  },
  "commands": {
    "install": "npm ci",
    "lint": "npm run lint",
    "typecheck": "npm run typecheck",
    "test": "",
    "build": "npm run build",
    "start": "npm run dev -- --hostname 0.0.0.0",
    "port": 3000
  },
  "cursor": {
    "dispatchMode": "linear-agent",
    "modelPolicy": "auto",
    "buildOptimization": "cost",
    "repairOptimization": "cost",
    "reviewOptimization": "balance",
    "allowFixedModelOverride": false
  },
  "review": {
    "provider": "greptile",
    "triggerMode": "factory-only",
    "repairSkill": "greploop",
    "requiredScore": "5/5",
    "requireZeroUnresolvedComments": true,
    "evidenceSkill": "evidence-driven-testing",
    "automationProvider": "cursor-automation",
    "triggerLabel": "factory-review-ready",
    "approvedLabel": "factory-approved",
    "changesRequestedLabel": "loop-changes-requested",
    "humanReviewLabel": "needs-human-review",
    "rerunOnPush": true,
    "humanMergeOnly": true
  },
  "repair": {
    "enabled": true,
    "provider": "greploop",
    "automationProvider": "cursor-automation",
    "triggerLabel": "loop-changes-requested",
    "runningLabel": "factory-repair-running",
    "limitLabel": "repair-limit-reached",
    "issueLabel": "factory-repair",
    "maxGreptileReviewIterations": 5,
    "humanContinueRequiredAfterLimit": true,
    "createLinearSubIssue": true,
    "reusePullRequest": true,
    "inheritBuildApproval": true
  },
  "learning": {
    "enabled": true,
    "automationProvider": "cursor-automation",
    "automationMemory": true,
    "sourceRepository": "jonashildenbrand2710/code-factory",
    "minimumIndependentSignals": 2,
    "proposalOnly": true,
    "humanMergeOnly": true
  },
  "preview": {
    "provider": "vercel",
    "required": true,
    "environment": "preview",
    "branch": "staging",
    "deployPullRequests": true
  },
  "notifications": {
    "provider": "linear",
    "mergeReady": {
      "includePullRequest": true,
      "includePreview": true,
      "includeEvidenceVideo": true,
      "includeEvidenceReport": true,
      "includeReviewVerdict": true
    }
  }
}
