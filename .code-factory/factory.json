{
  "$schema": "./factory.schema.json",
  "language": "de",
  "linear": {
    "teamKey": "JON",
    "readyLabel": "agent-ready",
    "blockedLabel": "blocked",
    "reviewStatus": "In Review"
  },
  "github": {
    "repository": "jonashildenbrand2710/landgut-seebuehne-vercel",
    "baseBranch": "main",
    "requiredChecks": ["quality"]
  },
  "commands": {
    "install": "npm ci",
    "lint": "npm run lint",
    "typecheck": "npm run typecheck",
    "test": "",
    "build": "npm run build",
    "start": "npm run dev -- --hostname 0.0.0.0",
    "port": 3000
  },
  "cursor": {
    "dispatchMode": "linear-agent",
    "modelPolicy": "auto",
    "buildOptimization": "cost",
    "repairOptimization": "cost",
    "reviewOptimization": "balance",
    "allowFixedModelOverride": false
  },
  "review": {
    "provider": "finn-review",
    "evidenceSkill": "evidence-driven-testing",
    "automationProvider": "cursor-automation",
    "triggerLabel": "factory-review-ready",
    "approvedLabel": "factory-approved",
    "changesRequestedLabel": "loop-changes-requested",
    "humanReviewLabel": "needs-human-review",
    "rerunOnPush": true,
    "humanMergeOnly": true
  },
  "repair": {
    "enabled": true,
    "automationProvider": "cursor-automation",
    "triggerLabel": "loop-changes-requested",
    "runningLabel": "factory-repair-running",
    "limitLabel": "repair-limit-reached",
    "issueLabel": "factory-repair",
    "maxAutomaticRoundsPerGate": 3,
    "createLinearSubIssue": true,
    "reusePullRequest": true,
    "inheritBuildApproval": true,
    "resetAfterHumanDecision": true
  },
  "preview": {
    "provider": "vercel",
    "required": true
  }
}
