# Public site configuration
NEXT_PUBLIC_SITE_URL=https://www.landgut-seebuehne.de
NEXT_PUBLIC_BOOKING_URL=/termin-buchen
NEXT_PUBLIC_ALT_BOOKING_URL=/besichtigungstermin-buchen

# Server-only CRM booking API for the internal calendar funnel
CRM_BOOKING_API_URL=
CRM_BOOKING_API_TOKEN=
CRM_BOOKING_FLOW_ID=website_booking
CRM_BOOKING_FLOW_VERSION=2026-06-v1

# Supabase Edge Function settings for website-booking
# 0=Sunday, 1=Monday, ..., 6=Saturday. End time includes the 120-minute duration.
WEBSITE_BOOKING_WINDOWS=[{"start":"10:00","end":"19:00","weekdays":[0,1,2,3,4]}]
# Local UI review only; production always uses the live calendar API.
BOOKING_AVAILABILITY_PREVIEW=false

